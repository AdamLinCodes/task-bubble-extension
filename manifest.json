{
  "manifest_version": 3,
  "name": "Task Bubble",
  "description": "A translucent floating bubble that keeps your current task visible on any page.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Task Bubble"
  },
  "commands": {
    "edit-task-bubble": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Edit the current task bubble text"
    },
    "toggle-task-history": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Show or hide task history"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
